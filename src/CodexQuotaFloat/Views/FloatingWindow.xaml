<Window x:Class="CodexQuotaFloat.Views.FloatingWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore" Width="340" Height="46" MinWidth="340" MaxWidth="340" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize">
  <Grid>
    <Border x:Name="CompactPanel" Background="#EA171B22" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="14" Padding="12,0" PreviewMouseLeftButtonDown="HeaderDrag">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <TextBlock Text="{Binding CompactTitle}" Foreground="#E9EDF3" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap"/>
        <Border Grid.Column="2" Height="30" Padding="9,0" Background="#1EFFFFFF" CornerRadius="9" VerticalAlignment="Center"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="4"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions><TextBlock Text="5h" Foreground="#B8C1CD" Opacity=".78" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding FiveCompactPercent}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
        <Border Grid.Column="4" Height="30" Padding="9,0" Background="#1EFFFFFF" CornerRadius="9" VerticalAlignment="Center"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="4"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions><TextBlock Text="周" Foreground="#B8C1CD" Opacity=".78" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding WeekCompactPercent}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
        <Button Grid.Column="6" Style="{StaticResource DarkActionButton}" Width="30" Height="30" Padding="0" Command="{Binding ToggleExpandedCommand}" ToolTip="展开详情" automation:AutomationProperties.Name="展开详情"><Path Data="M 4,7 L 10,13 L 16,7" Stroke="#DEE5ED" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
      </Grid>
    </Border>
    <Border x:Name="ExpandedPanel" Visibility="Collapsed" Background="#E9171B22" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="18" Padding="18">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,13" PreviewMouseLeftButtonDown="HeaderDrag"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Codex 额度" Foreground="#F8FAFC" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Ellipse Width="8" Height="8" Fill="#65C78A" Margin="0,0,7,0"/><TextBlock Text="{Binding Status}" Foreground="#D5DCE6" FontSize="12" Margin="0,0,12,0"/><TextBlock Text="{Binding UpdatedTime}" Foreground="#9CA8B6" FontSize="12"/></StackPanel></Grid>
        <Grid Grid.Row="1" Margin="0,0,0,11"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="5小时" Foreground="#DDE4ED" FontSize="13"/><TextBlock Grid.Column="1" Text="{Binding FiveDisplay}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold"/></Grid><ProgressBar Grid.Row="1" Style="{StaticResource QuotaProgress}" Value="{Binding FivePercent, Mode=OneWay}" Maximum="100" Foreground="#65C78A" HorizontalAlignment="Stretch" Margin="0,7,0,5"/><TextBlock Grid.Row="2" Text="{Binding FiveCountdown}" Foreground="#98A6B5" FontSize="11"/></Grid>
        <Grid Grid.Row="2" Margin="0,0,0,14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="每周" Foreground="#DDE4ED" FontSize="13"/><TextBlock Grid.Column="1" Text="{Binding WeekDisplay}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold"/></Grid><ProgressBar Grid.Row="1" Style="{StaticResource QuotaProgress}" Value="{Binding WeekPercent, Mode=OneWay}" Maximum="100" Foreground="#65C78A" HorizontalAlignment="Stretch" Margin="0,7,0,5"/><TextBlock Grid.Row="2" Text="{Binding WeekCountdown}" Foreground="#98A6B5" FontSize="11"/></Grid>
        <Grid Grid.Row="3" HorizontalAlignment="Right"><StackPanel Orientation="Horizontal"><Button Style="{StaticResource DarkActionButton}" Content="{Binding RefreshButtonText}" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/><Button Style="{StaticResource DarkActionButton}" Width="30" Height="30" Padding="0" Command="{Binding ToggleExpandedCommand}" ToolTip="收起详情" automation:AutomationProperties.Name="收起详情"><Path Data="M 4,13 L 10,7 L 16,13" Stroke="#DEE5ED" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button></StackPanel></Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
