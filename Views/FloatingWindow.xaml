<Window x:Class="CodexQuotaFloat.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="340" Height="46" MinWidth="340" MaxWidth="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize">
  <Grid>
    <Border x:Name="CompactPanel" Background="#EA171B22" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="14" Padding="14,0">
      <Grid VerticalAlignment="Center" MouseLeftButtonDown="HeaderDrag">
        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <TextBlock Text="Codex 剩余额度" Foreground="#F5F7FA" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
        <Border Grid.Column="2" Margin="12,0,0,0" Padding="8,3" Background="#14FFFFFF" CornerRadius="7"><StackPanel Orientation="Horizontal"><TextBlock Text="5h" Foreground="#AEB9C7" FontSize="13" Margin="0,0,5,0"/><TextBlock Text="{Binding FiveCompactPercent}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold"/></StackPanel></Border>
        <Border Grid.Column="3" Margin="7,0,0,0" Padding="8,3" Background="#14FFFFFF" CornerRadius="7"><StackPanel Orientation="Horizontal"><TextBlock Text="周" Foreground="#AEB9C7" FontSize="13" Margin="0,0,5,0"/><TextBlock Text="{Binding WeekCompactPercent}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold"/></StackPanel></Border>
        <Button Grid.Column="4" Style="{StaticResource DarkActionButton}" Width="28" Height="28" Padding="0" Margin="8,0,0,0" Content="˅" FontSize="15" Command="{Binding ToggleExpandedCommand}" ToolTip="展开额度详情"/>
      </Grid>
    </Border>

    <Border x:Name="ExpandedPanel" Visibility="Collapsed" Background="#E9171B22" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="18" Padding="18">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,13" MouseLeftButtonDown="HeaderDrag"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Codex 额度" Foreground="#F8FAFC" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Ellipse Width="8" Height="8" Fill="#65C78A" Margin="0,0,7,0"/><TextBlock Text="{Binding Status}" Foreground="#D5DCE6" FontSize="12" Margin="0,0,12,0"/><TextBlock Text="{Binding UpdatedTime}" Foreground="#9CA8B6" FontSize="12"/></StackPanel></Grid>
        <Grid Grid.Row="1" Margin="0,0,0,11"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="5小时" Foreground="#DDE4ED" FontSize="13"/><TextBlock Grid.Column="1" Text="{Binding FivePercent, StringFormat={}{0}%}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold"/></Grid><ProgressBar Grid.Row="1" Style="{StaticResource QuotaProgress}" Value="{Binding FivePercent, Mode=OneWay}" Maximum="100" Foreground="#65C78A" HorizontalAlignment="Stretch" Margin="0,7,0,5"/><TextBlock Grid.Row="2" Text="{Binding FiveCountdown}" Foreground="#98A6B5" FontSize="11"/></Grid>
        <Grid Grid.Row="2" Margin="0,0,0,14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="每周" Foreground="#DDE4ED" FontSize="13"/><TextBlock Grid.Column="1" Text="{Binding WeekPercent, StringFormat={}{0}%}" Foreground="#65C78A" FontSize="14" FontWeight="SemiBold"/></Grid><ProgressBar Grid.Row="1" Style="{StaticResource QuotaProgress}" Value="{Binding WeekPercent, Mode=OneWay}" Maximum="100" Foreground="#65C78A" HorizontalAlignment="Stretch" Margin="0,7,0,5"/><TextBlock Grid.Row="2" Text="{Binding WeekCountdown}" Foreground="#98A6B5" FontSize="11"/></Grid>
        <Grid Grid.Row="3" HorizontalAlignment="Right"><StackPanel Orientation="Horizontal"><Button Style="{StaticResource DarkActionButton}" Content="{Binding RefreshButtonText}" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/><Button Style="{StaticResource DarkActionButton}" Content="收起 ˄" Command="{Binding ToggleExpandedCommand}" ToolTip="收起额度详情"/></StackPanel></Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
